#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        //zmk,matrix_transform = &default_transform;
        zmk,physical-layout = &physical_layout0;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <6>;
// | MX1  | MX2  | MX3  | MX4  | MX5  | MX6  |                 | MX7  | MX8  | MX9  | MX10 | MX11 | MX12 |
// | MX13 | MX14 | MX15 | MX16 | MX17 | MX18 |                 | MX19 | MX20 | MX21 | MX22 | MX23 | MX24 |
// | MX25 | MX26 | MX27 | MX28 | MX29 | MX30 |                 | MX31 | MX32 | MX33 | MX34 | MX35 | MX36 |
// | MX37 | MX38 | MX39 | MX40 | MX41 | MX42 |                 | MX43 | MX44 | MX45 | MX46 | MX47 | MX48 |
//        | MX49 | MX50 | MX51 | MX52 |                               | MX53 | MX54 | MX55 | MX56 |
//                                    | MX57 | MX58 |   | MX59 | MX60 |
//                                           | MX61 |   | MX62 |
//                             | MX63 | MX64 | MX65 |   | MX66 | MX67 | MX68 |
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                   RC(0,11) RC(0,10) RC(0,9) RC(0,8) RC(0,7) RC(0,6)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                   RC(1,11) RC(1,10) RC(1,9) RC(1,8) RC(1,7) RC(1,6)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)                   RC(2,11) RC(2,10) RC(2,9) RC(2,8) RC(2,7) RC(2,6)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)                   RC(3,11) RC(3,10) RC(3,9) RC(3,8) RC(3,7) RC(3,6)
        RC(4,1) RC(4,2) RC(4,3) RC(4,4)                                    RC(4,10) RC(4,9) RC(4,8) RC(4,7)
                                        RC(4,5) RC(5,5)  RC(5,11) RC(4,11)
                                                RC(5,1)  RC(5,7)
                                RC(5,4) RC(5,3) RC(5,2)  RC(5,8)  RC(5,9) RC(5,10)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";

        diode-direction = "col2row";
        row-gpios
            = <&gpio0 9  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 0 from the schematic file
            , <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 1 from the schematic file
            , <&gpio1 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 2 from the schematic file
            , <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 3 from the schematic file
            , <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 4 from the schematic file
            , <&gpio0 2  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 5 from the schematic file
            ;

    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        // Coordinate system:
        // - centiunits (100 = 1 key width)
        // - Column stagger (y offsets, relative to C2 which is highest):
        //     C0/C11 (pinky outer) : +75
        //     C1/C10 (pinky)       : +50
        //     C2/C9  (ring)        :  +0  ← highest
        //     C3/C8  (middle)      : +10
        //     C4/C7  (index)       : +30
        //     C5/C6  (index inner) : +60
        // - Thumb clusters offset below main block, rotated ±1000 centidegrees (10°)
        //   Left cluster:  rot=+1000 (CW),  pivot top-left of cluster
        //   Right cluster: rot=-1000 (CCW), pivot top-right of cluster
        //
        // Left thumb shape:       Right thumb shape:
        //     [N][N]                   [N][N]
        //   [L][L][N]               [N][L][L]
        //   [L][L][N]               [N][L][L]

        keys  //                     w    h      x     y    rot    rx    ry

            // ── ROW 0 ───────────────────────────────────────────────────
            // Left  RC(0,0)–RC(0,5)
            = <&key_physical_attrs 100  100      0    75      0     0     0>  // RC(0,0)  C0
            , <&key_physical_attrs 100  100    100    50      0     0     0>  // RC(0,1)  C1
            , <&key_physical_attrs 100  100    200     0      0     0     0>  // RC(0,2)  C2 highest
            , <&key_physical_attrs 100  100    300    10      0     0     0>  // RC(0,3)  C3
            , <&key_physical_attrs 100  100    400    30      0     0     0>  // RC(0,4)  C4
            , <&key_physical_attrs 100  100    500    60      0     0     0>  // RC(0,5)  C5
            // Right RC(0,11)–RC(0,6) — mirrored stagger
            , <&key_physical_attrs 100  100   1100    75      0     0     0>  // RC(0,11) C11
            , <&key_physical_attrs 100  100   1000    50      0     0     0>  // RC(0,10) C10
            , <&key_physical_attrs 100  100    900     0      0     0     0>  // RC(0,9)  C9
            , <&key_physical_attrs 100  100    800    10      0     0     0>  // RC(0,8)  C8
            , <&key_physical_attrs 100  100    700    30      0     0     0>  // RC(0,7)  C7
            , <&key_physical_attrs 100  100    600    60      0     0     0>  // RC(0,6)  C6

            // ── ROW 1 ───────────────────────────────────────────────────
            // Left  RC(1,0)–RC(1,5)
            , <&key_physical_attrs 100  100      0   175      0     0     0>  // RC(1,0)
            , <&key_physical_attrs 100  100    100   150      0     0     0>  // RC(1,1)
            , <&key_physical_attrs 100  100    200   100      0     0     0>  // RC(1,2)
            , <&key_physical_attrs 100  100    300   110      0     0     0>  // RC(1,3)
            , <&key_physical_attrs 100  100    400   130      0     0     0>  // RC(1,4)
            , <&key_physical_attrs 100  100    500   160      0     0     0>  // RC(1,5)
            // Right RC(1,11)–RC(1,6)
            , <&key_physical_attrs 100  100   1100   175      0     0     0>  // RC(1,11)
            , <&key_physical_attrs 100  100   1000   150      0     0     0>  // RC(1,10)
            , <&key_physical_attrs 100  100    900   100      0     0     0>  // RC(1,9)
            , <&key_physical_attrs 100  100    800   110      0     0     0>  // RC(1,8)
            , <&key_physical_attrs 100  100    700   130      0     0     0>  // RC(1,7)
            , <&key_physical_attrs 100  100    600   160      0     0     0>  // RC(1,6)

            // ── ROW 2 (home row) ────────────────────────────────────────
            // Left  RC(2,0)–RC(2,5)
            , <&key_physical_attrs 100  100      0   275      0     0     0>  // RC(2,0)
            , <&key_physical_attrs 100  100    100   250      0     0     0>  // RC(2,1)
            , <&key_physical_attrs 100  100    200   200      0     0     0>  // RC(2,2)
            , <&key_physical_attrs 100  100    300   210      0     0     0>  // RC(2,3)
            , <&key_physical_attrs 100  100    400   230      0     0     0>  // RC(2,4)
            , <&key_physical_attrs 100  100    500   260      0     0     0>  // RC(2,5)
            // Right RC(2,11)–RC(2,6)
            , <&key_physical_attrs 100  100   1100   275      0     0     0>  // RC(2,11)
            , <&key_physical_attrs 100  100   1000   250      0     0     0>  // RC(2,10)
            , <&key_physical_attrs 100  100    900   200      0     0     0>  // RC(2,9)
            , <&key_physical_attrs 100  100    800   210      0     0     0>  // RC(2,8)
            , <&key_physical_attrs 100  100    700   230      0     0     0>  // RC(2,7)
            , <&key_physical_attrs 100  100    600   260      0     0     0>  // RC(2,6)

            // ── ROW 3 ───────────────────────────────────────────────────
            // Left  RC(3,0)–RC(3,5)
            , <&key_physical_attrs 100  100      0   375      0     0     0>  // RC(3,0)
            , <&key_physical_attrs 100  100    100   350      0     0     0>  // RC(3,1)
            , <&key_physical_attrs 100  100    200   300      0     0     0>  // RC(3,2)
            , <&key_physical_attrs 100  100    300   310      0     0     0>  // RC(3,3)
            , <&key_physical_attrs 100  100    400   330      0     0     0>  // RC(3,4)
            , <&key_physical_attrs 100  100    500   360      0     0     0>  // RC(3,5)
            // Right RC(3,11)–RC(3,6)
            , <&key_physical_attrs 100  100   1100   375      0     0     0>  // RC(3,11)
            , <&key_physical_attrs 100  100   1000   350      0     0     0>  // RC(3,10)
            , <&key_physical_attrs 100  100    900   300      0     0     0>  // RC(3,9)
            , <&key_physical_attrs 100  100    800   310      0     0     0>  // RC(3,8)
            , <&key_physical_attrs 100  100    700   330      0     0     0>  // RC(3,7)
            , <&key_physical_attrs 100  100    600   360      0     0     0>  // RC(3,6)

            // ── ROW 4 ───────────────────────────────────────────────────
            // Left  RC(4,1)–RC(4,4) — no C0 or C5
            , <&key_physical_attrs 100  100    100   450      0     0     0>  // RC(4,1)
            , <&key_physical_attrs 100  100    200   400      0     0     0>  // RC(4,2)
            , <&key_physical_attrs 100  100    300   410      0     0     0>  // RC(4,3)
            , <&key_physical_attrs 100  100    400   430      0     0     0>  // RC(4,4)
            // Right RC(4,10)–RC(4,7) — no C11 or C6
            , <&key_physical_attrs 100  100   1000   450      0     0     0>  // RC(4,10)
            , <&key_physical_attrs 100  100    900   400      0     0     0>  // RC(4,9)
            , <&key_physical_attrs 100  100    800   410      0     0     0>  // RC(4,8)
            , <&key_physical_attrs 100  100    700   430      0     0     0>  // RC(4,7)

            // ── ROW 5 — THUMB CLUSTERS ──────────────────────────────────
            //
            // Transform order for row 5:
            //   RC(4,5)  RC(5,5)   RC(5,11) RC(4,11)    ← top row
            //            RC(5,1)   RC(5,7)              ← mid
            //   RC(5,4)  RC(5,3)   RC(5,2)  RC(5,8)  RC(5,9)  RC(5,10)  ← bottom
            //
            // Left cluster layout (rot=+1000, pivot=500,520):
            //       [RC(4,5)][RC(5,5)]       top — 2 normal, right-aligned
            //   [RC(5,1)][RC(5,4)][RC(5,3)]  mid — 2u | 2u | normal
            //   [RC(5,1)][RC(5,4)][RC(5,2)]  bot — tall keys continue | normal
            //
            // Right cluster layout (rot=-1000, pivot=800,520):
            //   [RC(5,11)][RC(4,11)]          top — 2 normal, left-aligned
            //   [RC(5,9)] [RC(5,7)][RC(5,8)]  mid — normal | 2u | 2u
            //   [RC(5,10)][RC(5,7)][RC(5,8)]  bot — normal | tall continues
            //
            // Left thumb — top row (2 normal, right-aligned over col1+col2)
            , <&key_physical_attrs 100  100    500   520   1000   400   520>  // RC(4,5)  top-left normal
            , <&key_physical_attrs 100  100    600   520   1000   400   520>  // RC(5,5)  top-right normal
            // Right thumb — top row (2 normal, left-aligned over col0+col1)
            , <&key_physical_attrs 100  100    700   520  (-1000)  800   520>  // RC(5,11) top-left normal
            , <&key_physical_attrs 100  100    800   520  (-1000)  800   520>  // RC(4,11) top-right normal
            // Left thumb — RC(5,1) mid (will become 2u tall key)
            , <&key_physical_attrs 100  200    400   550   1000   400   520>  // RC(5,1)  2u tall col0
            // Right thumb — RC(5,7) mid
            , <&key_physical_attrs 100  200    800   550  (-1000)  800   520>  // RC(5,7)  2u tall col1
            // Left thumb — bottom row
            , <&key_physical_attrs 100  200    500   550   1000   400   520>  // RC(5,4)  2u tall col1
            , <&key_physical_attrs 100  100    600   550   1000   400   520>  // RC(5,3)  normal col2 top
            , <&key_physical_attrs 100  100    600   650   1000   400   520>  // RC(5,2)  normal col2 bot
            // Right thumb — bottom row
            , <&key_physical_attrs 100  100    700   550  (-1000)  800   520>  // RC(5,9)  normal col0 top
            , <&key_physical_attrs 100  100    700   650  (-1000)  800   520>  // RC(5,10) normal col0 bot
            , <&key_physical_attrs 100  200    800   550  (-1000)  800   520>  // RC(5,8)  2u tall col2
            ;
    };

    //physical_layout0: physical_layout_0 {
    //    compatible = "zmk,physical-layout";
    //    display-name = "Dactyl CC Layout";
    //    transform = <&default_transform>;
    //    kscan = <&kscan0>;

    //    // Units: 100 = 1 key width
    //    // Column stagger offsets applied
    //    // Split gap ≈ 300
    //    // Thumb clusters rotated ±12°

    //    keys  //                     w    h      x     y    rot    rx    ry

    //        // ───────── ROW 0 ─────────
    //        = <&key_physical_attrs 100 100    0    75   0 0 0>
    //        , <&key_physical_attrs 100 100  100    50   0 0 0>
    //        , <&key_physical_attrs 100 100  200     0   0 0 0>
    //        , <&key_physical_attrs 100 100  300    10   0 0 0>
    //        , <&key_physical_attrs 100 100  400    30   0 0 0>
    //        , <&key_physical_attrs 100 100  500    60   0 0 0>

    //        , <&key_physical_attrs 100 100  900    75   0 0 0>
    //        , <&key_physical_attrs 100 100  800    50   0 0 0>
    //        , <&key_physical_attrs 100 100  700     0   0 0 0>
    //        , <&key_physical_attrs 100 100  600    10   0 0 0>
    //        , <&key_physical_attrs 100 100  500    30   0 0 0>
    //        , <&key_physical_attrs 100 100  400    60   0 0 0>

    //        // ───────── ROW 1 ─────────
    //        , <&key_physical_attrs 100 100    0   175   0 0 0>
    //        , <&key_physical_attrs 100 100  100   150   0 0 0>
    //        , <&key_physical_attrs 100 100  200   100   0 0 0>
    //        , <&key_physical_attrs 100 100  300   110   0 0 0>
    //        , <&key_physical_attrs 100 100  400   130   0 0 0>
    //        , <&key_physical_attrs 100 100  500   160   0 0 0>

    //        , <&key_physical_attrs 100 100  900   175   0 0 0>
    //        , <&key_physical_attrs 100 100  800   150   0 0 0>
    //        , <&key_physical_attrs 100 100  700   100   0 0 0>
    //        , <&key_physical_attrs 100 100  600   110   0 0 0>
    //        , <&key_physical_attrs 100 100  500   130   0 0 0>
    //        , <&key_physical_attrs 100 100  400   160   0 0 0>

    //        // ───────── ROW 2 ─────────
    //        , <&key_physical_attrs 100 100    0   275   0 0 0>
    //        , <&key_physical_attrs 100 100  100   250   0 0 0>
    //        , <&key_physical_attrs 100 100  200   200   0 0 0>
    //        , <&key_physical_attrs 100 100  300   210   0 0 0>
    //        , <&key_physical_attrs 100 100  400   230   0 0 0>
    //        , <&key_physical_attrs 100 100  500   260   0 0 0>

    //        , <&key_physical_attrs 100 100  900   275   0 0 0>
    //        , <&key_physical_attrs 100 100  800   250   0 0 0>
    //        , <&key_physical_attrs 100 100  700   200   0 0 0>
    //        , <&key_physical_attrs 100 100  600   210   0 0 0>
    //        , <&key_physical_attrs 100 100  500   230   0 0 0>
    //        , <&key_physical_attrs 100 100  400   260   0 0 0>

    //        // ───────── ROW 3 ─────────
    //        , <&key_physical_attrs 100 100    0   375   0 0 0>
    //        , <&key_physical_attrs 100 100  100   350   0 0 0>
    //        , <&key_physical_attrs 100 100  200   300   0 0 0>
    //        , <&key_physical_attrs 100 100  300   310   0 0 0>
    //        , <&key_physical_attrs 100 100  400   330   0 0 0>
    //        , <&key_physical_attrs 100 100  500   360   0 0 0>

    //        , <&key_physical_attrs 100 100  900   375   0 0 0>
    //        , <&key_physical_attrs 100 100  800   350   0 0 0>
    //        , <&key_physical_attrs 100 100  700   300   0 0 0>
    //        , <&key_physical_attrs 100 100  600   310   0 0 0>
    //        , <&key_physical_attrs 100 100  500   330   0 0 0>
    //        , <&key_physical_attrs 100 100  400   360   0 0 0>

    //        // ───────── ROW 4 (inner 4 keys per side) ─────────
    //        , <&key_physical_attrs 100 100  100   450   0 0 0>
    //        , <&key_physical_attrs 100 100  200   400   0 0 0>
    //        , <&key_physical_attrs 100 100  300   410   0 0 0>
    //        , <&key_physical_attrs 100 100  400   430   0 0 0>

    //        , <&key_physical_attrs 100 100  800   450   0 0 0>
    //        , <&key_physical_attrs 100 100  700   400   0 0 0>
    //        , <&key_physical_attrs 100 100  600   410   0 0 0>
    //        , <&key_physical_attrs 100 100  500   430   0 0 0>

    //        // ───────── THUMB CLUSTERS ─────────
    //        // Left pivot (350,520) | Right pivot (850,520)

    //        , <&key_physical_attrs 100 100  520 500 1200 350 520>
    //        , <&key_physical_attrs 100 100  470 580 1200 350 520>
    //        , <&key_physical_attrs 100 100  880 580 (-1200) 850 520>
    //        , <&key_physical_attrs 100 100  830 500 (-1200) 850 520>

    //        , <&key_physical_attrs 100 100  420 660 1200 350 520>
    //        , <&key_physical_attrs 100 100  930 660 (-1200) 850 520>

    //        , <&key_physical_attrs 100 100  570 520 1200 350 520>
    //        , <&key_physical_attrs 100 100  520 600 1200 350 520>
    //        , <&key_physical_attrs 100 100  470 680 1200 350 520>

    //        , <&key_physical_attrs 100 100  880 680 (-1200) 850 520>
    //        , <&key_physical_attrs 100 100  930 600 (-1200) 850 520>
    //        , <&key_physical_attrs 100 100  980 520 (-1200) 850 520>
    //        ;
    //};
};
