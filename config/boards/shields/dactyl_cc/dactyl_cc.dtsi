#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        //zmk,matrix_transform = &default_transform;
        zmk,physical-layout = &physical_layout0;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <6>;
// | MX1  | MX2  | MX3  | MX4  | MX5  | MX6  |                 | MX7  | MX8  | MX9  | MX10 | MX11 | MX12 |
// | MX13 | MX14 | MX15 | MX16 | MX17 | MX18 |                 | MX19 | MX20 | MX21 | MX22 | MX23 | MX24 |
// | MX25 | MX26 | MX27 | MX28 | MX29 | MX30 |                 | MX31 | MX32 | MX33 | MX34 | MX35 | MX36 |
// | MX37 | MX38 | MX39 | MX40 | MX41 | MX42 |                 | MX43 | MX44 | MX45 | MX46 | MX47 | MX48 |
//        | MX49 | MX50 | MX51 | MX52 |                               | MX53 | MX54 | MX55 | MX56 |
//                                    | MX57 | MX58 |   | MX59 | MX60 |
//                                           | MX61 |   | MX62 |
//                             | MX63 | MX64 | MX65 |   | MX66 | MX67 | MX68 |
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                   RC(0,11) RC(0,10) RC(0,9) RC(0,8) RC(0,7) RC(0,6)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                   RC(1,11) RC(1,10) RC(1,9) RC(1,8) RC(1,7) RC(1,6)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)                   RC(2,11) RC(2,10) RC(2,9) RC(2,8) RC(2,7) RC(2,6)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)                   RC(3,11) RC(3,10) RC(3,9) RC(3,8) RC(3,7) RC(3,6)
        RC(4,1) RC(4,2) RC(4,3) RC(4,4)                                    RC(4,10) RC(4,9) RC(4,8) RC(4,7)
                                        RC(4,5) RC(5,5)  RC(5,11) RC(4,11)
                                                RC(5,1)  RC(5,7)
                                RC(5,4) RC(5,3) RC(5,2)  RC(5,8)  RC(5,9) RC(5,10)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";

        diode-direction = "col2row";
        row-gpios
            = <&gpio0 9  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 0 from the schematic file
            , <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 1 from the schematic file
            , <&gpio1 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 2 from the schematic file
            , <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 3 from the schematic file
            , <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 4 from the schematic file
            , <&gpio0 2  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 5 from the schematic file
            ;

    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        // Coordinate system notes:
        // - Units are centiunits (100 = 1 key width ~19mm)
        // - x increases left→right, y increases top→bottom
        // - Column stagger (y offsets relative to col2 which is highest):
        //     C0 (pinky outer) : +75
        //     C1 (pinky)       : +50
        //     C2 (ring)        :  +0  ← highest column
        //     C3 (middle)      : +10
        //     C4 (index)       : +30
        //     C5 (index inner) : +60
        // - Thumb cluster is offset below and right of main block,
        //   rotated 10° clockwise (1000 centidegrees)
        //   pivot point is top-left corner of cluster

        keys  //                     w    h      x     y    rot    rx    ry

            // ── ROW 0 ──────────────────────────────────────────────────
            // Left  RC(0,0)–RC(0,5)
            = <&key_physical_attrs 100  100      0    75      0     0     0>  // L00 C0
            , <&key_physical_attrs 100  100    100    50      0     0     0>  // L01 C1
            , <&key_physical_attrs 100  100    200     0      0     0     0>  // L02 C2 ← highest
            , <&key_physical_attrs 100  100    300    10      0     0     0>  // L03 C3
            , <&key_physical_attrs 100  100    400    30      0     0     0>  // L04 C4
            , <&key_physical_attrs 100  100    500    60      0     0     0>  // L05 C5
            // Right RC(0,11)–RC(0,6) — mirrored stagger
            , <&key_physical_attrs 100  100   1100    75      0     0     0>  // R00 C11
            , <&key_physical_attrs 100  100   1000    50      0     0     0>  // R01 C10
            , <&key_physical_attrs 100  100    900     0      0     0     0>  // R02 C9
            , <&key_physical_attrs 100  100    800    10      0     0     0>  // R03 C8
            , <&key_physical_attrs 100  100    700    30      0     0     0>  // R04 C7
            , <&key_physical_attrs 100  100    600    60      0     0     0>  // R05 C6

            // ── ROW 1 ──────────────────────────────────────────────────
            // Left  RC(1,0)–RC(1,5)
            , <&key_physical_attrs 100  100      0   175      0     0     0>  // L10
            , <&key_physical_attrs 100  100    100   150      0     0     0>  // L11
            , <&key_physical_attrs 100  100    200   100      0     0     0>  // L12
            , <&key_physical_attrs 100  100    300   110      0     0     0>  // L13
            , <&key_physical_attrs 100  100    400   130      0     0     0>  // L14
            , <&key_physical_attrs 100  100    500   160      0     0     0>  // L15
            // Right RC(1,11)–RC(1,6)
            , <&key_physical_attrs 100  100   1100   175      0     0     0>  // R10
            , <&key_physical_attrs 100  100   1000   150      0     0     0>  // R11
            , <&key_physical_attrs 100  100    900   100      0     0     0>  // R12
            , <&key_physical_attrs 100  100    800   110      0     0     0>  // R13
            , <&key_physical_attrs 100  100    700   130      0     0     0>  // R14
            , <&key_physical_attrs 100  100    600   160      0     0     0>  // R15

            // ── ROW 2 (home row) ───────────────────────────────────────
            // Left  RC(2,0)–RC(2,5)
            , <&key_physical_attrs 100  100      0   275      0     0     0>  // L20
            , <&key_physical_attrs 100  100    100   250      0     0     0>  // L21
            , <&key_physical_attrs 100  100    200   200      0     0     0>  // L22
            , <&key_physical_attrs 100  100    300   210      0     0     0>  // L23
            , <&key_physical_attrs 100  100    400   230      0     0     0>  // L24
            , <&key_physical_attrs 100  100    500   260      0     0     0>  // L25
            // Right RC(2,11)–RC(2,6)
            , <&key_physical_attrs 100  100   1100   275      0     0     0>  // R20
            , <&key_physical_attrs 100  100   1000   250      0     0     0>  // R21
            , <&key_physical_attrs 100  100    900   200      0     0     0>  // R22
            , <&key_physical_attrs 100  100    800   210      0     0     0>  // R23
            , <&key_physical_attrs 100  100    700   230      0     0     0>  // R24
            , <&key_physical_attrs 100  100    600   260      0     0     0>  // R25

            // ── ROW 3 ──────────────────────────────────────────────────
            // Left  RC(3,0)–RC(3,5)
            , <&key_physical_attrs 100  100      0   375      0     0     0>  // L30
            , <&key_physical_attrs 100  100    100   350      0     0     0>  // L31
            , <&key_physical_attrs 100  100    200   300      0     0     0>  // L32
            , <&key_physical_attrs 100  100    300   310      0     0     0>  // L33
            , <&key_physical_attrs 100  100    400   330      0     0     0>  // L34
            , <&key_physical_attrs 100  100    500   360      0     0     0>  // L35
            // Right RC(3,11)–RC(3,6)
            , <&key_physical_attrs 100  100   1100   375      0     0     0>  // R30
            , <&key_physical_attrs 100  100   1000   350      0     0     0>  // R31
            , <&key_physical_attrs 100  100    900   300      0     0     0>  // R32
            , <&key_physical_attrs 100  100    800   310      0     0     0>  // R33
            , <&key_physical_attrs 100  100    700   330      0     0     0>  // R34
            , <&key_physical_attrs 100  100    600   360      0     0     0>  // R35

            // ── ROW 4 ──────────────────────────────────────────────────
            // Left  RC(4,1)–RC(4,4) — no col0 or col5
            , <&key_physical_attrs 100  100    100   450      0     0     0>  // L41
            , <&key_physical_attrs 100  100    200   400      0     0     0>  // L42
            , <&key_physical_attrs 100  100    300   410      0     0     0>  // L43
            , <&key_physical_attrs 100  100    400   430      0     0     0>  // L44
            // Right RC(4,10)–RC(4,7) — no col11 or col6
            , <&key_physical_attrs 100  100   1000   450      0     0     0>  // R41
            , <&key_physical_attrs 100  100    900   400      0     0     0>  // R42
            , <&key_physical_attrs 100  100    800   410      0     0     0>  // R43
            , <&key_physical_attrs 100  100    700   430      0     0     0>  // R44

            // ── ROW 5 — THUMB CLUSTERS ─────────────────────────────────
            //
            // Left thumb cluster shape (rotated 10° CW):
            //   top row  : [ RC5,4 ][ RC5,3 ][ RC5,2 ]   ← 3 normal keys
            //   mid+bot  : [ RC5,5 ][ RC5,1 ]             ← 2 × 2u tall
            //              (RC5,0 is inner-right normal below top row)
            //
            // Transform order for row 5:
            //   RC(5,4) RC(5,5)  RC(5,11) RC(5,10)
            //           RC(5,3)  RC(5,9)
            //   RC(5,2) RC(5,1)  RC(5,0)  RC(5,6)  RC(5,7)  RC(5,8)
            //
            // Cluster anchor: x=320, y=520
            // rot=1000 centidegrees (10°), pivot at anchor point
            //
            // Left thumb — top row (3 normal keys, inner→outer left)
            , <&key_physical_attrs 100  100    520   520   1000   320   520>  // RC(5,4) top inner
            , <&key_physical_attrs 100  200    420   550   1000   320   520>  // RC(5,5) 2u tall outer-left
            , <&key_physical_attrs 100  200    820   550   (-1000)   980   520>  // RC(5,11) 2u tall right half
            , <&key_physical_attrs 100  100    780   520   (-1000)   980   520>  // RC(5,10) top inner right
            , <&key_physical_attrs 100  100    420   520   1000   320   520>  // RC(5,3) top mid-left
            , <&key_physical_attrs 100  100    880   520   (-1000)   980   520>  // RC(5,9) top mid-right
            , <&key_physical_attrs 100  100    320   520   1000   320   520>  // RC(5,2) top outer-left
            , <&key_physical_attrs 100  200    320   550   1000   320   520>  // RC(5,1) 2u tall leftmost
            , <&key_physical_attrs 100  100    520   550   1000   320   520>  // RC(5,0) normal below inner
            , <&key_physical_attrs 100  100    980   520   (-1000)   980   520>  // RC(5,6) top outer-right
            , <&key_physical_attrs 100  200    880   550   (-1000)   980   520>  // RC(5,7) 2u tall right
            , <&key_physical_attrs 100  200    980   550   (-1000)   980   520>  // RC(5,8) 2u tall rightmost
            ;
    };
};
